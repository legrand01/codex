# Backend Dockerfile - Autonomous Postgres DBA Agent Platform
# Multi-stage build for production-ready image

FROM python:3.11-slim@sha256:db3ff2e1800a8581e2c48a27c3995339d47bdf046da21c7627accd3d51053a93 AS base

WORKDIR /app

# Install system dependencies (curl for health checks)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install the audited production dependency lock first for layer caching.
COPY requirements.lock ./
RUN pip install --no-cache-dir --requirement requirements.lock

# Copy application code
COPY backend/ ./backend/
COPY host_agent/ ./host_agent/

# Create non-root user for security
RUN adduser --disabled-password --gecos "" appuser && \
    mkdir -p /var/lib/dbtune-agent && \
    chown -R appuser:appuser /app /var/lib/dbtune-agent
USER appuser

# Expose port
EXPOSE 8000

# Health check - must respond HTTP 200 within 30 seconds of container start
HEALTHCHECK --interval=5s --timeout=5s --start-period=15s --retries=6 \
    CMD curl -f http://localhost:8000/health/ready || exit 1

# Run application with production settings
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2", "--access-log"]
