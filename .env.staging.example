# Copy to .env.staging with scripts/staging_init.py. Never commit that file.
COMPOSE_PROJECT_NAME=dbtune-staging
RELEASE_COMMIT_SHA=CHANGE_ME_40_CHARACTER_GIT_COMMIT
BIND_ADDRESS=127.0.0.1
PORT=18000
FRONTEND_PORT=18080
STAGING_HTTPS_PORT=18443
PG_PORT=15432
REDIS_PORT=16379
TARGET_PG_PORT=55433

# Keep the long-running local transaction lab representative without saturating
# the staging host. A rate of 0 means unlimited and is not suitable for a soak.
STAGING_PGBENCH_CLIENTS=2
STAGING_PGBENCH_JOBS=2
STAGING_PGBENCH_RATE=2
STAGING_TARGET_POSTGRES_CPUS=2.0
STAGING_TARGET_POSTGRES_MEMORY=2g
STAGING_TARGET_WORKLOAD_CPUS=0.5
STAGING_TARGET_WORKLOAD_MEMORY=128m

ENVIRONMENT=production
DEBUG=false
DEMO_MODE=false
AUTH_REQUIRED=true
AGENT_AUTH_REQUIRED=true
CORS_ORIGINS=["https://staging.dbtune.example"]

# Replace every CHANGE_ME value. URL-encode reserved password characters in DSNs.
POSTGRES_USER=dbtune_bootstrap
POSTGRES_PASSWORD=CHANGE_ME_BOOTSTRAP_DATABASE_PASSWORD
POSTGRES_DB=dba_agent
POSTGRES_MIGRATION_PASSWORD=CHANGE_ME_MIGRATION_DATABASE_PASSWORD
POSTGRES_RUNTIME_PASSWORD=CHANGE_ME_RUNTIME_DATABASE_PASSWORD
POSTGRES_BACKUP_PASSWORD=CHANGE_ME_BACKUP_DATABASE_PASSWORD
MIGRATION_DATABASE_URL=postgresql://dbtune_migrator:CHANGE_ME_MIGRATION_DATABASE_PASSWORD@postgres:5432/dba_agent
CONTROL_DATABASE_URL=postgresql://dbtune_runtime:CHANGE_ME_RUNTIME_DATABASE_PASSWORD@postgres:5432/dba_agent
BACKUP_DATABASE_URL=postgresql://dbtune_backup:CHANGE_ME_BACKUP_DATABASE_PASSWORD@postgres:5432/dba_agent

# The disposable tuning target mirrors the same least-privilege boundary:
# bootstrap owns the cluster, the agent reads telemetry/reloads the managed
# include, and the workload can modify only its application tables.
TARGET_POSTGRES_USER=dbtune_lab_bootstrap
TARGET_POSTGRES_PASSWORD=CHANGE_ME_TARGET_BOOTSTRAP_PASSWORD
TARGET_AGENT_USER=dbtune_agent
TARGET_AGENT_PASSWORD=CHANGE_ME_TARGET_AGENT_PASSWORD
TARGET_WORKLOAD_USER=dbtune_workload
TARGET_WORKLOAD_PASSWORD=CHANGE_ME_TARGET_WORKLOAD_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
CONTROL_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
BOOTSTRAP_ADMIN_TOKEN=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

# Writes remain disabled through the entire staging soak. A later production
# approval must change all three interlocks deliberately.
WRITE_EXECUTION_ENABLED=false
PRODUCTION_WRITE_ENABLED=false
PRODUCTION_WRITE_CONFIRMATION=

EVIDENCE_CLEANUP_ENABLED=true
EVIDENCE_RAW_RETENTION_DAYS=30
EVIDENCE_REFERENCED_RETENTION_DAYS=90
EVIDENCE_ROLLUP_RETENTION_DAYS=365
EVIDENCE_CLEANUP_INTERVAL_SECONDS=3600
EVIDENCE_CLEANUP_BATCH_SIZE=1000
EVIDENCE_CLEANUP_MAX_BATCHES=20

BACKUP_INTERVAL_SECONDS=3600
BACKUP_RETENTION_DAYS=14
ALERT_WEBHOOK_URL=CHANGE_ME_HTTPS_ALERT_RECEIVER

# Tuning lab identity values are provisioned after registering the target.
TARGET_AGENT_HOST_ID=
TARGET_AGENT_TOKEN=
TARGET_AGENT_INSTANCE_ID=f9e89d36-f4cb-4f31-8b3a-e8a92fb4a916
