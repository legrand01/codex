# Application
APP_NAME=Autonomous Postgres DBA Agent Platform
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dba_agent
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Demo Mode
DEMO_MODE=false

# Guardrail defaults
RISK_THRESHOLD=70
DRY_RUN_TIMEOUT_SEC=30
APPROVAL_TIMEOUT_HOURS=24

# Loop Worker defaults
MAX_ITERATIONS=10
MAX_STEPS=20
VERIFICATION_WINDOW_SEC=60
DEGRADATION_THRESHOLD_PCT=10.0

# Host Agent defaults
AGENT_HOST_ID=
AGENT_HOSTNAME=w2j
# For a host PostgreSQL service file entry on Linux Docker, use host.docker.internal
# and add the password if the target user requires one.
PG_CONNECTION_STRING=postgresql://pgai_user@host.docker.internal:5444/w2jmon_test?sslmode=require
PG_SETTINGS_INTERVAL=60
PG_STATS_INTERVAL=30
LOCKS_REPLICATION_INTERVAL=15
OS_METRICS_INTERVAL=15
MAX_QUERY_ENTRIES=100
HEARTBEAT_INTERVAL=30
# Explicit enrollment only. Leave false unless the matching execution backend
# has been installed, tested, and approved for this host.
RESTART_CAPABILITY=false
PROVIDER_API_CAPABILITY=false
MANAGED_FILE_ACCESS=false
# Required only for explicitly enrolled self-managed hosts. The Host Agent must
# see this exact PostgreSQL-side path and its parent directory.
MANAGED_CONF_PATH=
COMMAND_POLL_INTERVAL=2
